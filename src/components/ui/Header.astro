---
import { t } from '../../i18n';
import '../../styles/header.css';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';

const sectionPrefix = Astro.url.pathname === '/' ? '' : '/';

const navigationItems = [
  {
    href: `${sectionPrefix}#about`,
    key: 'about-me',
    className: 'hidden sm:block',
  },
  {
    href: `${sectionPrefix}#projects`,
    key: 'projects',
  },
  {
    href: `${sectionPrefix}#contact`,
    key: 'contact',
    className: 'hidden sm:block',
  },
] as const;

const navLinkClass =
  'flex h-11 items-center text-[0.65rem] font-medium uppercase tracking-[0.18em] text-(--text-secondary) transition-colors duration-200 hover:text-(--primary) sm:h-auto';
---

<header
  class="site-header pointer-events-none fixed inset-x-0 top-0 z-30 flex items-start justify-between gap-5 py-2 sm:items-center sm:px-8 lg:px-10"
  data-site-header
  data-scrolled="false"
>
  <a
    href="/"
    aria-label="Go to homepage"
    class="pointer-events-auto max-w-40 lg:max-w-none pl-2 lg:pl-0 text-sm font-semibold leading-tight tracking-[-0.04em] text-(--text-primary) transition-colors duration-200 hover:text-(--primary)"
  >
    Suzanna Khachatryan - Portfolio
  </a>

  <nav
    aria-label="Navigation"
    class="pointer-events-auto flex items-start gap-4 sm:items-center sm:gap-6"
  >
    {
      navigationItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            navLinkClass,
            'className' in item ? item.className : undefined,
          ]}
          data-i18n={item.key}
        >
          {t(item.key)}
        </a>
      ))
    }

    <div
      class="flex flex-col items-end sm:ml-8 sm:flex-row sm:items-center sm:gap-2"
    >
      <LanguageSwitcher />

      <div class="-mt-1 pr-2 sm:mt-0 sm:pr-0">
        <ThemeSwitcher />
      </div>
    </div>
  </nav>
</header>

<script>
  function updateHeaderBackground(): void {
    const header = document.querySelector<HTMLElement>('[data-site-header]');
    const heroEyebrow = document.querySelector<HTMLElement>('.hero-eyebrow');

    if (!header) return;

    if (!heroEyebrow) {
      header.dataset.scrolled = 'true';
      return;
    }

    const eyebrowHasReachedHeader =
      heroEyebrow.getBoundingClientRect().top <= header.offsetHeight;

    header.dataset.scrolled = String(eyebrowHasReachedHeader);
  }

  function initializeHeaderScrollState(): void {
    updateHeaderBackground();

    if (document.documentElement.dataset.headerScrollListener === 'true') {
      return;
    }

    document.documentElement.dataset.headerScrollListener = 'true';
    window.addEventListener('scroll', updateHeaderBackground, {
      passive: true,
    });
    window.addEventListener('resize', updateHeaderBackground);
  }

  initializeHeaderScrollState();
  document.addEventListener('astro:page-load', initializeHeaderScrollState);
</script>
