---
import { Moon, Sun } from '@lucide/astro';
import Button from './Button.astro';
---

<Button
  class="theme-switcher"
  data-theme-switcher
  data-current-theme="light"
  aria-label="Schakel naar donkere modus"
>
  <Sun
    size={14}
    stroke-width={2}
    aria-hidden="true"
    class="theme-switcher__icon theme-switcher__icon--sun"
  />

  <Moon
    size={14}
    stroke-width={2}
    aria-hidden="true"
    class="theme-switcher__icon theme-switcher__icon--moon"
  />
</Button>

<style>
  .theme-switcher {
    position: relative;

    display: grid;
    place-items: center;

    width: 2.5rem;
    height: 1.75rem;
    min-width: 2.5rem;
    min-height: 1.75rem;
    border-radius: 0.68rem;
  }

  .theme-switcher__icon {
    position: absolute;

    transition:
      opacity 220ms ease,
      transform 320ms cubic-bezier(0.34, 1.35, 0.64, 1);
  }

  .theme-switcher__icon--sun {
    fill: none;
    color: var(--primary);
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .theme-switcher__icon--moon {
    fill: var(--primary);
    color: var(--text-primary);
    opacity: 0;
    transform: rotate(-25deg) scale(0.65);
  }

  .theme-switcher[data-current-theme='dark'] .theme-switcher__icon--sun {
    opacity: 0;
    transform: rotate(25deg) scale(0.65);
  }

  .theme-switcher[data-current-theme='dark'] .theme-switcher__icon--moon {
    fill: var(--surface-hover);
    color: var(--surface-hover);
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-switcher__icon {
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  type Theme = 'light' | 'dark';

  const storageKey = 'portfolio-theme';

  function getStoredTheme(): Theme {
    return localStorage.getItem(storageKey) === 'dark' ? 'dark' : 'light';
  }

  function updateThemeSwitcher(theme: Theme): void {
    document
      .querySelectorAll<HTMLButtonElement>('[data-theme-switcher]')
      .forEach((button) => {
        button.dataset.currentTheme = theme;

        button.setAttribute(
          'aria-label',
          theme === 'light'
            ? 'Schakel naar donkere modus'
            : 'Schakel naar lichte modus',
        );
      });
  }

  function applyTheme(theme: Theme): void {
    if (theme === 'dark') {
      document.documentElement.dataset.theme = 'dark';
    } else {
      delete document.documentElement.dataset.theme;
    }

    document.documentElement.style.colorScheme = theme;

    localStorage.setItem(storageKey, theme);

    updateThemeSwitcher(theme);

    window.dispatchEvent(
      new CustomEvent<Theme>('themechange', {
        detail: theme,
      }),
    );
  }

  function initializeThemeSwitcher(): void {
    const theme = getStoredTheme();

    applyTheme(theme);

    document
      .querySelectorAll<HTMLButtonElement>('[data-theme-switcher]')
      .forEach((button) => {
        if (button.dataset.listenerAttached === 'true') {
          return;
        }

        button.dataset.listenerAttached = 'true';

        button.addEventListener('click', () => {
          const currentTheme =
            button.dataset.currentTheme === 'dark' ? 'dark' : 'light';

          const nextTheme: Theme = currentTheme === 'light' ? 'dark' : 'light';

          applyTheme(nextTheme);
        });
      });
  }

  initializeThemeSwitcher();

  document.addEventListener('astro:page-load', initializeThemeSwitcher);

  window.addEventListener('themechange', (event) => {
    const customEvent = event as CustomEvent<Theme>;

    updateThemeSwitcher(customEvent.detail);
  });
</script>
