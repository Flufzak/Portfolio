---
import { projects } from '../data/projects';
import { t } from '../i18n';
import ProjectCard from './ProjectCard.astro';
import LoadMore from './ui/LoadMore.astro';
---

<section id="projects" class="py-13">
  <div class="mb-10 sm:mb-12">
    <h2 data-i18n="projects">{t('projects')}</h2>
  </div>

  <div
    id="project-grid"
    class="wide-container grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8 2xl:grid-cols-3"
  >
    {
      projects.map((project, index) => (
        <div
          class:list={['h-full', { 'hidden lg:block': index >= 2 }]}
          data-load-more-item={index >= 2 ? '' : undefined}
        >
          <ProjectCard project={project} />
        </div>
      ))
    }
  </div>

  {
    projects.length > 2 && (
      <LoadMore targetId="project-grid" translationKey="load-more-projects" />
    )
  }
</section>
