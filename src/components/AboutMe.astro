---
import { Blocks, Brush, Server } from '@lucide/astro';
import { t } from '../i18n';
import type { TranslationKey } from '../i18n';

const buildItems = [
  { icon: Brush, title: 'frontend', description: 'frontend-description' },
  { icon: Server, title: 'backend', description: 'backend-description' },
  { icon: Blocks, title: 'full-stack', description: 'full-stack-description' },
] satisfies Array<{
  icon: typeof Brush;
  title: TranslationKey;
  description: TranslationKey;
}>;
---

<section id="about">
  <div
    class="relative left-1/2 h-px w-screen -translate-x-1/2 bg-linear-to-r from-transparent via-(--text-muted) to-transparent opacity-60"
    aria-hidden="true"
  >
  </div>

  <div
    class="grid items-center gap-8 py-13 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1fr)] lg:gap-20"
  >
    <div class="max-w-3xl">
      <h2 class="mb-6">Hi!</h2>

      <p
        data-i18n="about-intro"
        class="whitespace-pre-line text-(--text-secondary)"
      >
        {t('about-intro')}
      </p>
    </div>

    <img
      data-theme-image
      data-light-src="/assets/aboutmelight.png"
      data-dark-src="/assets/aboutmedark.png"
      alt="Code editor illustration"
      loading="lazy"
      decoding="async"
      class="content-image hidden h-auto w-full max-w-208 justify-self-center lg:block"
    />
  </div>

  <section
    class="relative left-1/2 w-screen -translate-x-1/2 bg-(--primary) text-(--surface)"
    aria-labelledby="what-i-build-heading"
  >
    <div class="page-container py-13">
      <h2
        id="what-i-build-heading"
        class="text-center"
        data-i18n="what-i-build"
      >
        {t('what-i-build')}
      </h2>

      <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
        {
          buildItems.map(({ icon: Icon, title, description }) => (
            <article class="flex flex-col items-center text-center">
              <div
                class="flex size-20 items-center justify-center rounded-full border-2 border-current bg-transparent"
                aria-hidden="true"
              >
                <Icon class="size-9" stroke-width={2} />
              </div>

              <h3 class="mt-6 text-xl" data-i18n={title}>
                {t(title)}
              </h3>

              <p class="mt-3 max-w-sm text-sm" data-i18n={description}>
                {t(description)}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</section>
