---
import { t } from '../i18n';
import Header from './ui/Header.astro';

const lightSplineUrl =
  'https://my.spline.design/untitled-Q4yHJgcAbK933uRjhvSy9Il6/';

const darkSplineUrl = 'https://my.spline.design/dark-hIFTv9GnsPoJyutFNaGzAtKt/';
---

<section
  class="relative min-h-[88svh] overflow-hidden bg-(--background) text-(--text-primary) sm:min-h-svh"
>
  <div class="absolute inset-x-0 top-20 z-0 h-[40vh] sm:inset-0 sm:h-auto">
    <iframe
      id="hero-spline"
      src={lightSplineUrl}
      data-light-src={lightSplineUrl}
      data-dark-src={darkSplineUrl}
      data-active-theme="light"
      title="Interactief 3D-logo"
      loading="eager"
      allow="autoplay; fullscreen"
      class="block h-full w-full border-0"></iframe>
  </div>

  <Header />

  <div
    class="hero-content page-padding pointer-events-none absolute inset-x-0 top-[53vh] z-20 sm:top-auto sm:bottom-8 lg:bottom-12"
  >
    <div class="flex min-w-0 flex-col gap-3 pr-6 sm:gap-4">
      <div class="hero-eyebrow" data-i18n="fullStackDeveloper">
        {t('fullStackDeveloper')}
      </div>

      <h1 class="hero-heading" data-i18n="hero-title">
        {t('hero-title')}
      </h1>
    </div>
  </div>

  <div
    class="hero-microcopy hero-side-copy pointer-events-none absolute right-(--spline-badge-right) bottom-(--spline-copy-bottom) z-20 hidden w-48 flex-col text-right sm:flex"
  >
    <p data-i18n="based-in-belgium">{t('based-in-belgium')}</p>
    <p data-i18n="available-worldwide">{t('available-worldwide')}</p>
  </div>
</section>

<script is:inline>
  const splineFrame = document.querySelector('#hero-spline');
  const root = document.documentElement;

  const updateSplineTheme = () => {
    if (!(splineFrame instanceof HTMLIFrameElement)) return;

    const nextTheme = root.dataset.theme === 'dark' ? 'dark' : 'light';

    if (splineFrame.dataset.activeTheme === nextTheme) return;

    const nextSource =
      nextTheme === 'dark'
        ? splineFrame.dataset.darkSrc
        : splineFrame.dataset.lightSrc;

    if (!nextSource) return;

    splineFrame.dataset.activeTheme = nextTheme;
    splineFrame.src = nextSource;
  };

  updateSplineTheme();

  const themeObserver = new MutationObserver(updateSplineTheme);

  themeObserver.observe(root, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
</script>
